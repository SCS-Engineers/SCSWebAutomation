# SCS Web Automation - Environment Variables Template
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env file to version control

# Valid User Credentials
VALID_USER_USERNAME=
VALID_USER_PASSWORD=
VALID_USER_FIRSTNAME=
VALID_USER_LASTNAME=

# Non-Applicable User Credentials
NON_APPLICABLE_USER_USERNAME=
NON_APPLICABLE_USER_PASSWORD=

# No Access User Credentials
NO_ACCESS_USER_USERNAME=
NO_ACCESS_USER_PASSWORD=

# Invalid Username Test User
INVALID_USERNAME_USER=
INVALID_USERNAME_PASSWORD=

# Invalid Password Test User
INVALID_PASSWORD_USERNAME=
INVALID_PASSWORD_PASSWORD=

# Invalid Both Credentials
INVALID_BOTH_USERNAME=
INVALID_BOTH_PASSWORD=

# Application URLs
LOGIN_PAGE_URL=
HOME_PAGE_URL=

# Change Password Test Data
CHANGE_PASSWORD_INITIAL=
CHANGE_PASSWORD_NEW=
CHANGE_PASSWORD_INVALID=
